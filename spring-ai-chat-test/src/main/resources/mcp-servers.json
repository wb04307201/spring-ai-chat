{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "bing-search": {
      "args": [
        "-y",
        "bing-cn-mcp"
      ],
      "command": "npx.cmd"
    },
    "time": {
      "command": "uvx",
      "args": [
        "mcp-server-time",
        "--local-timezone=Asia/Shanghai"
      ]
    },
    "fetch": {
      "args": [
        "mcp-server-fetch"
      ],
      "command": "uvx"
    },
    "cn-weather-mcp": {
      "args": [
        "io.github.wb04307201:cn-weather-mcp:1.0.0"
      ],
      "command": "jbang.cmd"
    },
    "amap-maps": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@amap/amap-maps-mcp-server"
      ],
      "env": {
      }
    },
    "12306-mcp": {
      "args": [
        "-y",
        "12306-mcp"
      ],
      "command": "npx.cmd"
    },
    "mcp-server-chart": {
      "args": [
        "-y",
        "@antv/mcp-server-chart"
      ],
      "command": "npx.cmd"
    },
    "tavily-mcp": {
      "args": [
        "-y",
        "tavily-mcp@0.1.4"
      ],
      "command": "npx.cmd",
      "env": {
      }
    },
    "juhe-mcp-server": {
      "command": "uvx",
      "args": [
        "juhe-mcp-proxy",
        "https://mcp.juhe.cn/sse?token=RfXYPzmZigD4rTEkqSbUJgfi7AqqvVQgEpMTP4A8METwcr"
      ],
      "env": {
        "LOG_LEVEL": "CRITICAL"
      }
    }
  }
}