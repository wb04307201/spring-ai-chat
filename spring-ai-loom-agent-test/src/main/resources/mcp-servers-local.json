{
  "mcpServers": {
    "time": {
      "command": "uvx",
      "args": [
        "mcp-server-time",
        "--local-timezone=Asia/Shanghai"
      ]
    },
    "sequential-thinking": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "http-client-mcp": {
      "args": [
        "io.github.wb04307201:http-mcp:1.0.0"
      ],
      "command": "jbang.cmd"
    }
  }
}